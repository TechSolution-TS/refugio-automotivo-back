<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-create-servicos" author="lucas">
        <createTable tableName="servicos">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="uuid" type="VARCHAR(40)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="nome" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="preco" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>

            <column name="descricao" type="VARCHAR(255)"/>

            <column name="descricao_completa" type="TEXT"/>

            <column name="destaques" type="TEXT"/>

            <column name="tempo" type="VARCHAR(255)"/>
        </createTable>

        <addAutoIncrement tableName="servicos" columnName="id" columnDataType="BIGINT"/>

        <createIndex indexName="idx_servicos_uuid" tableName="servicos">
            <column name="uuid"/>
        </createIndex>

        <createIndex indexName="idx_servicos_nome" tableName="servicos">
            <column name="nome"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
