<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-usuarios" author="lucas">
        <createTable tableName="usuarios">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="uuid" type="VARCHAR(40)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="cpf" type="VARCHAR(14)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="nome" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>

            <column name="telefone" type="VARCHAR(20)"/>

            <column name="endereco_uuid" type="VARCHAR(40)"/>

            <column name="data_criacao" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addAutoIncrement tableName="usuarios" columnName="id" columnDataType="BIGINT"/>

        <createIndex indexName="idx_usuarios_uuid" tableName="usuarios">
            <column name="uuid"/>
        </createIndex>

        <createIndex indexName="idx_usuarios_cpf" tableName="usuarios">
            <column name="cpf"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>